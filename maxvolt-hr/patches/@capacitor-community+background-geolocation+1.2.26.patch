+        String action = intent.getAction();
+        if (
+                !Intent.ACTION_BOOT_COMPLETED.equals(action)
+                && !"android.intent.action.QUICKBOOT_POWERON".equals(action)
+        ) {
+            return;
+        }
+
+        SharedPreferences prefs = context.getSharedPreferences(
+                BackgroundGeolocationService.HEADLESS_PREFS, Context.MODE_PRIVATE
+        );
+        boolean trackingActive = prefs.getBoolean(BackgroundGeolocationService.PREF_TRACKING_ACTIVE, false);
+        if (!trackingActive) return;
+
+        Intent serviceIntent = new Intent(context, BackgroundGeolocationService.class);
+        serviceIntent.setAction(BackgroundGeolocationService.ACTION_START_HEADLESS);
+        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
+            context.startForegroundService(serviceIntent);
+        } else {
+            context.startService(serviceIntent);
+        }
+    }
+}
